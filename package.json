{
  "name": "liveflow-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prepare": "husky",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "bunx biome check --write --staged",
      "git add"
    ],
    "*.{css,scss,md}": [
      "bunx biome format --write --staged",
      "git add"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prisma": "7.8.0",
    "tsx": "4.22.4"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "fastify": "5.9.0",
    "fastify-type-provider-zod": "7.0.0",
    "jsonwebtoken": "9.0.3",
    "socket.io": "4.8.3",
    "zod": "4.4.3",
    "zod-to-json-schema": "3.25.2"
  }
}
